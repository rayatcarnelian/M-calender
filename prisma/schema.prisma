generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  password      String
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  events          Event[]
  businessProfile BusinessProfile?
  settings        Settings?
  trendingVideos  TrendingVideo[]
}

model Event {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  start     DateTime
  end       DateTime?
  type      String   @default("meeting") // "meeting" | "social"
  platform  String?  // "linkedin" | "twitter" | "instagram" etc.
  content   String?
  color     String?  // backgroundColor
  imageUrl     String?  // AI-generated image URL
  videoUrl     String?  // Uploaded completed MP4 video
  assetPackRef String?  // Reference to the downloaded asset pack if applicable
  status       String   @default("pending") // "pending" | "published" | "failed"
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BusinessProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  businessName    String
  industry        String
  targetAudience  String
  platforms       String   // comma-separated: "linkedin,twitter,instagram"
  brandVoice      String
  monthlyTheme    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Settings {
  id                    String   @id
  user                  User     @relation(fields: [id], references: [id], onDelete: Cascade)
  // Facebook / Meta
  facebookClientId      String?
  facebookClientSecret  String?
  facebookAccessToken   String?
  // Instagram (uses Meta Graph API, same app as Facebook)
  instagramAccessToken  String?
  // X (Twitter)
  twitterClientId       String?
  twitterClientSecret   String?
  twitterAccessToken    String?
  // LinkedIn
  linkedinClientId      String?
  linkedinClientSecret  String?
  linkedinAccessToken   String?
  // YouTube (Google)
  youtubeClientId       String?
  youtubeClientSecret   String?
  youtubeAccessToken    String?
  youtubeRefreshToken   String?
  // AI Provider Keys
  geminiApiKey          String?
  groqApiKey            String?
  falApiKey             String?
  apifyApiKey           String?
  togetherApiKey        String?
  pexelsApiKey          String?
  elevenLabsApiKey      String? // Host A
  elevenLabsApiKey2     String? // Host B
  
  // Data Scraper Keys
  rapidApiKey           String?
  youtubeApiKey         String?
  
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model TrendingVideo {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  platform        String   // "youtube", "tiktok", "instagram"
  url             String
  author          String?
  title           String?
  thumbnailUrl    String?
  views           Int      @default(0)
  likes           Int      @default(0)
  comments        Int      @default(0)
  scrapedAt       DateTime @default(now())
  isAnalyzed      Boolean  @default(false)
  
  // Data populated after AI analysis
  hookExposed     String?
  visualStyle     String?
  masterPrompt    String?
  toolsIdentified String?  // JSON: tools/software the creator likely used
  stepByStepGuide String?  // JSON: step-by-step recreation guide
  costBreakdown   String?  // JSON: free/budget/premium cost tiers
}
